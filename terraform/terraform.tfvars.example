# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored.
region           = "eu-west-3"
name             = "web"
instance_type    = "t3.micro"
instance_count   = 2                    # provision a fleet, not a single box
key_name         = "my-keypair"        # an existing EC2 key pair name
ssh_ingress_cidr = "203.0.113.4/32"    # your ip only, never 0.0.0.0/0
tags = {
  Owner = "ammar"
  Env   = "demo"
}
